#!/bin/sh
# Reject commits with AI attribution
if grep -qiE '(claude|anthropic|co-authored-by.*noreply@anthropic|generated by ai|ai assistant)' "$1"; then
  echo "ERROR: Commit message contains AI attribution."
  echo "This project prohibits AI references in commits."
  echo "Remove any Claude/AI/Anthropic/Co-Authored-By lines."
  exit 1
fi
